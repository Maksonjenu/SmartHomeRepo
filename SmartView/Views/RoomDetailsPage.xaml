<Page x:Class="SmartView.Views.RoomDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Детали комнаты"
      Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Информация о комнате" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Padding="20"
                   Foreground="#333"/>

        <!-- Содержимое -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <!-- Загрузка -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,20">
                    <ProgressBar IsIndeterminate="True" Height="4" Foreground="#4CAF50" Margin="0,0,0,10"/>
                    <TextBlock Text="Загрузка информации..." Foreground="#666"/>
                </StackPanel>

                <!-- Ошибка -->
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="Red"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringEmptyToVisibility}}"
                           Margin="0,0,0,20"/>

                <!-- Информация комнаты -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolInverseToVisibility}, Mode=OneWay}">
                    <!-- Название -->
                    <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Название" FontWeight="Bold" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Room.Name}" FontSize="16" Foreground="#333"/>
                        </StackPanel>
                    </Border>

                    <!-- Тип комнаты -->
                    <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Тип комнаты" FontWeight="Bold" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Room.RoomType}" FontSize="16" Foreground="#333"/>
                        </StackPanel>
                    </Border>

                    <!-- Площадь с слайдером -->
                    <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Площадь (м²)" FontWeight="Bold" Foreground="#666"/>
                                <TextBlock Text="{Binding Room.Area, StringFormat=' {0:F1}'}" FontSize="14" Foreground="#333" Margin="10,0,0,0"/>
                            </StackPanel>
                            <Slider Value="{Binding Room.Area, Mode=TwoWay}" 
                                    Minimum="10" 
                                    Maximum="100" 
                                    SmallChange="1"
                                    LargeChange="5"/>
                            <TextBlock Text="Слайдер для демонстрации (учебный пример)" FontSize="10" Foreground="#999" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Температура с слайдером -->
                    <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Температура (°C)" FontWeight="Bold" Foreground="#666"/>
                                <TextBlock Text="{Binding Room.Temperature, StringFormat=' {0:F1}'}" FontSize="14" Foreground="#333" Margin="10,0,0,0"/>
                            </StackPanel>
                            <Slider Value="{Binding Room.Temperature, Mode=TwoWay}" 
                                    Minimum="15" 
                                    Maximum="30" 
                                    SmallChange="0.5"
                                    LargeChange="1"/>
                            <TextBlock Text="Слайдер для демонстрации (учебный пример)" FontSize="10" Foreground="#999" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Состояние света -->
                    <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox IsChecked="{Binding Room.LightState, Mode=TwoWay}" VerticalAlignment="Center"/>
                                <TextBlock Text="Свет включен" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="Чекбокс для демонстрации (учебный пример)" FontSize="10" Foreground="#999" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопка назад -->
        <Button Grid.Row="2"
                Command="{Binding GoBackCommand}"
                Content="← Назад"
                Width="120"
                Height="40"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,20"
                Background="#999"
                Foreground="White"
                FontSize="14"
                Cursor="Hand"/>
    </Grid>
</Page>

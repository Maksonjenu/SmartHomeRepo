<Page x:Class="SmartView.Views.RoomsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Комнаты"
      Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="{Binding ApartmentTitle}" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Padding="20"
                   Foreground="#333"/>

        <!-- Содержимое -->
        <Grid Grid.Row="1">
            <!-- Загрузка -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <ProgressBar IsIndeterminate="True" Height="4" Width="100" Foreground="#4CAF50" Margin="0,0,0,10"/>
                <TextBlock Text="Загрузка комнат..." HorizontalAlignment="Center" Foreground="#666"/>
            </StackPanel>

            <!-- Ошибка -->
            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="Red"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringEmptyToVisibility}}"/>

            <!-- Список комнат -->
            <ListBox ItemsSource="{Binding Rooms}"
                     SelectedItem="{Binding SelectedRoom}"
                     Background="Transparent"
                     BorderThickness="0"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolInverseToVisibility}, Mode=OneWay}"
                     Padding="10">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" 
                                BorderBrush="#DDD" 
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="15"
                                Margin="0,0,0,10"
                                MouseLeftButtonUp="Border_MouseLeftButtonUp">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" 
                                           FontSize="16" 
                                           FontWeight="Bold"
                                           Foreground="#333"/>
                                <TextBlock Text="{Binding RoomType}" 
                                           FontSize="12"
                                           Foreground="#999"
                                           Margin="0,5,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding Temperature, StringFormat='Т: {0:F1}°C'}" 
                                               FontSize="11"
                                               Foreground="#666"
                                               Margin="0,0,15,0"/>
                                    <TextBlock Text="{Binding Area, StringFormat='S: {0:F1}м²'}" 
                                               FontSize="11"
                                               Foreground="#666"
                                               Margin="0,0,15,0"/>
                                    <TextBlock Text="{Binding LightState, StringFormat='💡: {0}'}" 
                                               FontSize="11"
                                               Foreground="#666"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>

        <!-- Кнопки внизу -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20">
            <Button Command="{Binding GoBackCommand}"
                    Content="← Назад"
                    Width="120"
                    Height="40"
                    Background="#999"
                    Foreground="White"
                    FontSize="14"
                    Cursor="Hand"
                    Margin="0,0,10,0"/>

            <Button Command="{Binding SelectRoomCommand}"
                    Content="Подробнее →"
                    Width="120"
                    Height="40"
                    Background="#4CAF50"
                    Foreground="White"
                    FontSize="14"
                    Cursor="Hand"
                    Visibility="{Binding SelectedRoom, Converter={StaticResource NullToVisibility}, Mode=OneWay}"/>
        </StackPanel>
    </Grid>
</Page>

<Page x:Class="SmartView.Views.ApartmentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Квартиры"
      Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Все квартиры" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Padding="20"
                   Foreground="#333"/>

        <!-- Содержимое -->
        <Grid Grid.Row="1">
            <!-- Загрузка -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <ProgressBar IsIndeterminate="True" Height="4" Width="100" Foreground="#4CAF50" Margin="0,0,0,10"/>
                <TextBlock Text="Загрузка квартир..." HorizontalAlignment="Center" Foreground="#666"/>
            </StackPanel>

            <!-- Ошибка -->
            <TextBlock Grid.Row="1" 
                       Text="{Binding ErrorMessage}" 
                       Foreground="Red"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringEmptyToVisibility}}"/>

            <!-- Список квартир -->
            <ListBox ItemsSource="{Binding Apartments}"
                     SelectedItem="{Binding SelectedApartment}"
                     Background="Transparent"
                     BorderThickness="0"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolInverseToVisibility}, Mode=OneWay}"
                     Padding="10">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" 
                                BorderBrush="#DDD" 
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="15"
                                Margin="0,0,0,10"
                                MouseLeftButtonUp="Border_MouseLeftButtonUp">
                            <StackPanel>
                                <TextBlock Text="{Binding Number, StringFormat='Квартира #{0}'}" 
                                           FontSize="16" 
                                           FontWeight="Bold"
                                           Foreground="#333"/>
                                <TextBlock Text="{Binding Description}" 
                                           FontSize="12"
                                           Foreground="#999"
                                           Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding RoomsCount, StringFormat='Комнат: {0}'}" 
                                           FontSize="12"
                                           Foreground="#666"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Кнопка выбора -->
            <Button Command="{Binding SelectApartmentCommand}"
                    Content="Открыть"
                    Width="120"
                    Height="40"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20"
                    Background="#4CAF50"
                    Foreground="White"
                    FontSize="14"
                    Cursor="Hand"
                    Visibility="{Binding SelectedApartment, Converter={StaticResource NullToVisibility}, Mode=OneWay}"/>
        </Grid>
    </Grid>
</Page>
